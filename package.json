    "repair-non-imaging": "cmd /c scripts\\with-proxy.cmd node scripts/repair-non-imaging-galleries.mjs",
    "restore-all": "node scripts/restore-all.mjs",
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "start-dev": "cmd /c scripts\\start-dev.cmd",
    "build": "node scripts/generate-site-lite.mjs",
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "@vercel/kv": "^3.0.0",
    "cookie-session": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "undici": "^8.5.0"
