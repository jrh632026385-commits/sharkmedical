    "build-urogenital": "node scripts/build-system-content.mjs urogenital",
    "build-female-repro": "node scripts/build-system-content.mjs female-repro",
    "build-endocrine": "node scripts/build-system-content.mjs endocrine",
    "build-head-neck": "node scripts/build-system-content.mjs head-neck",
    "build-breast": "node scripts/build-system-content.mjs breast",
    "build-hematolymph": "node scripts/build-system-content.mjs hematolymph",
    "build-systemic": "node scripts/build-system-content.mjs systemic",
    "build-system-icons": "node scripts/build-system-icons.mjs",
    "supplement-continue": "cmd /c scripts\\run-continue-gallery.cmd",
    "supplement-batch2-multi-source-log": "cmd /c scripts\\run-multi-source.cmd",
    "post-multi-source-batch2": "node scripts/post-multi-source-batch2.mjs",
