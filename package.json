    "generate-remaining-systems": "node scripts/generate-remaining-systems-catalog.mjs",
    "build-remaining-systems": "node scripts/build-all-remaining-systems.mjs",
    "generate-nav-fallback": "node scripts/generate-nav-fallback.mjs",
    "generate-site-lite": "node scripts/generate-site-lite.mjs",
    "prewarm-images": "node scripts/prewarm-image-cache.mjs",
    "backfill-openi-buckets": "node scripts/backfill-openi-buckets.mjs",
